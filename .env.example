CAIRNLY_DOMAIN=localhost
CAIRNLY_TELEMETRY_ENABLED=false

# Single source of truth: repo root `.env`. `apps/web/next.config.ts` loads it before Next boots.

POSTGRES_DB=cairnly
POSTGRES_USER=cairnly
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://cairnly:change-me@postgres:5432/cairnly
# Dev on host vs Compose Postgres: use port 5433 and same password as POSTGRES_PASSWORD below (Compose default is change-me unless you override).
BETTER_AUTH_URL=http://localhost:3000
# Extra browser origins Better Auth accepts (comma-separated). Use when dev runs on another port than BETTER_AUTH_URL, e.g. http://localhost:3002.
BETTER_AUTH_TRUSTED_ORIGINS=
# Optional client hint; mirrors BETTER_AUTH_URL if sign-in POSTs mis-resolve (use same host as the browser, e.g. not 127 vs localhost mismatches).
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-32-byte-secret
CAIRNLY_DEFAULT_WORKSPACE_ID=dev_workspace
# Optional workspace scoping for public lead forms (/f/[slug]); defaults match CAIRNLY_DEFAULT_WORKSPACE_ID.
# CAIRNLY_PUBLIC_FORM_WORKSPACE_ID=dev_workspace

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
