CAIRNLY_DOMAIN=localhost
CAIRNLY_TELEMETRY_ENABLED=false

# Single source of truth: repo root `.env`. `apps/web/next.config.ts` loads it before Next boots.

POSTGRES_DB=cairnly
POSTGRES_USER=cairnly
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://cairnly:change-me@postgres:5432/cairnly
# Dev on host vs Compose Postgres: use port 5433 and same password as POSTGRES_PASSWORD below (Compose default is change-me unless you override).
BETTER_AUTH_URL=http://localhost:3000
# Extra browser origins Better Auth accepts (comma-separated). Use when dev runs on another port than BETTER_AUTH_URL, e.g. http://localhost:3002.
BETTER_AUTH_TRUSTED_ORIGINS=
# Optional client hint; mirrors BETTER_AUTH_URL if sign-in POSTs mis-resolve (use same host as the browser, e.g. not 127 vs localhost mismatches).
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-32-byte-secret
CAIRNLY_DEFAULT_WORKSPACE_ID=dev_workspace
# When public `/f/[slug]` forms should resolve contacts/forms in another workspace than the default CRM workspace, set this (otherwise lookups use CAIRNLY_DEFAULT_WORKSPACE_ID).
# Must match seed/migrations workspace_id for form rows (`pnpm db:seed` creates slug `intake` in CAIRNLY_DEV_WORKSPACE_ID or dev_workspace).
# CAIRNLY_PUBLIC_FORM_WORKSPACE_ID=

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# --- Email (optional) ---
# Public base URL for tracking pixels / link redirects (no trailing slash).
# CAIRNLY_PUBLIC_URL=https://crm.example.com
# SMTP (BYO). Prefer CAIRNLY_ prefix; plain SMTP_* also supported in code.
# CAIRNLY_SMTP_HOST=
# CAIRNLY_SMTP_PORT=587
# CAIRNLY_SMTP_SECURE=0
# CAIRNLY_SMTP_USER=
# CAIRNLY_SMTP_PASS=
# CAIRNLY_SMTP_FROM=
# Gmail OAuth (IMAP); redirect must match Google Cloud console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
# Worker: set to 1 to skip scheduling IMAP sync cron in jobs package.
# CAIRNLY_DISABLE_IMAP_SYNC=0
