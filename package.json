{
  "name": "cairnly",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check && vitest run",
    "crm": "node --import tsx ./apps/cli/src/cli.ts",
    "db:generate": "pnpm --filter @cairnly/db db:generate",
    "db:migrate": "pnpm --filter @cairnly/db db:migrate",
    "db:seed": "pnpm --filter @cairnly/db db:seed",
    "lint": "turbo lint",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "tsx": "^4.21.0",
    "turbo": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
